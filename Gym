<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Polaad Fitness Club | Sambhaji Gym & Fitness Center</title>
    <style>
        /* CSS for Design and Color Theme (Black & Yellow) */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #111;
            color: #fff;
        }

        /* Header & Navigation */
        header {
            background-color: #000;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 3px solid #ff0099;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            color: #ff009d;
        }

        nav a {
            color: #fff;
            text-decoration: none;
            margin-left: 20px;
            font-weight: bold;
        }

        nav a:hover {
            color: #ff00a2;
        }

        /* Hero Banner Section */
        .hero {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=1350&q=80') no-repeat center center/cover;
            height: 70vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 20px;
        }

        .hero h1 {
            font-size: 50px;
            color: #ff00f2;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .hero p {
            font-size: 20px;
            margin-bottom: 20px;
        }

        .btn {
            background-color: #ff00c3;
            color: #000;
            padding: 12px 30px;
            text-decoration: none;
            font-weight: bold;
            border-radius: 5px;
            font-size: 18px;
            transition: 0.3s;
        }

        .btn:hover {
            background-color: #fff;
        }

        /* Common Section Styles */
        .section {
            padding: 60px 20px;
            max-width: 1200px;
            margin: auto;
            text-align: center;
        }

        .section h2 {
            font-size: 32px;
            margin-bottom: 30px;
            color: #ff00d9;
            text-transform: uppercase;
        }

        /* Services Grid */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .service-card {
            background-color: #222;
            padding: 30px;
            border-radius: 8px;
            border: 1px solid #333;
            transition: 0.3s;
        }

        .service-card:hover {
            border-color: #ff00a2;
            transform: translateY(-5px);
        }

        /* Membership Plans Grid */
        .plans-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        .plan-card {
            background-color: #222;
            padding: 40px 20px;
            border-radius: 8px;
            border-top: 5px solid #f700ff;
        }

        .price {
            font-size: 36px;
            color: #ff00bb;
            margin: 15px 0;
            font-weight: bold;
        }

        /* Contact Section Info */
        .contact-info {
            font-size: 18px;
            line-height: 1.8;
        }

        
    footer {
            background-color: #000;
            text-align: center;
            padding: 20px;
            color: #777;
            border-top: 1px solid #222;
        }
    </style>
</head>
<body>

    <!-- 1. Header & Navigation Menu -->
    <header>
        <div class="logo">🏋️‍♂️ Polaad Fitness Club</div>
        <nav>
            <a href="#services">Facilities</a>
            <a href="#plans">Plans</a>
            <a href="#contact">Contact</a>
        </nav>
    </header>

    <!-- 2. Hero Section / Main Banner -->
    <section class="hero">
        <h1>Sweat More, Become Stronger!</h1>
        <p>The finest, state-of-the-art gym and fitness center in Sangola.</p>
        <a href="https://wa.me/919999999999" class="btn" target="_blank">Join Now via WhatsApp</a>
    </section>

    <!-- 3. Facilities / Services Section -->
    <section id="services" class="section">
        <h2>Our Facilities</h2>
        <div class="services-grid">
            <div class="service-card">
                <h3>Weight Training</h3>
                <p>Equipped with all modern strength machines and premium free weights.</p>
            </div>
            <div class="service-card">
                <h3>Cardio Section</h3>
                <p>Top-notch treadmills, cross-trainers, and cycles for effective weight loss.</p>
            </div>
            <div class="service-card">
                <h3>Zumba & Yoga</h3>
                <p>Special weekend group classes led by certified expert trainers.</p>
            </div>
        </div>
    </section>

    <!-- 4. Membership Pricing Plans Section -->
    <section id="plans" class="section">
        <h2>Membership Plans</h2>
        <div class="plans-grid">
            <div class="plan-card">
                <h3>1 Month</h3>
                <div class="price">₹ 1,500</div>
                <p>Standard general gym access</p>
            </div>
            <div class="plan-card">
                <h3>3 Months</h3>
                <div class="price">₹ 3,000</div>
                <p>Includes a complimentary personalized diet plan</p>
            </div>
            <div class="plan-card">
                <h3>2 Year</h3>
                <div class="price">₹ 11,000</div>
                <p>Get 1 months extra free + personal guidance orientation</p>
            </div>
        </div>
    </section>

    <!-- 5. Contact & Location Information Section -->
    <section id="contact" class="section" style="background-color: #1a1a1a;">
        <h2>Contact Us</h2>
        <div class="contact-info">
            <p><strong>📍 Address:</strong> Lawate Building Gala No. 5, Mahud,Sangola</p>
            <p><strong>📞 Phone Number:</strong> +91 9309230992</p>
            <p><strong>⏰ Gym Timings:</strong> Sunday to Saturday: 4:00 AM - 09:00 PM (Sundays Open)</p>
            <br>
            <a href="https://wa.me/919999999999" class="btn" target="_blank">View on Google Maps</a>
        </div>
    </section>

    <!-- 6. Footer Section -->
    <footer>
        <p>&copy; 2026 Polaad Fitness Club. All Rights Reserved. | Designed for Client</p>
    </footer>

</body>
</html>
